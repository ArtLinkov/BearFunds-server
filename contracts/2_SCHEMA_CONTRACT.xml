<!--
  Canonical: BearFunds-server · v1.6.1
  This repo is the canonical home for the shared client<->server Schema Contract
  (re-home decided in the brain's Sources of Truth, 2026-06-01; executed 2026-06-02).
  It is NOT casually editable. Any change is a deliberate version bump with a one-line
  rationale; the operator drops the versioned copy into the client (downstream consumer).
  v1.6.1: removed the isDirty global column note - the client retired the transient flag; the Mutation outbox is the sole pending-sync signal (L4 Stage 2).
-->
<SchemaContract version="1.6.1">
  <Meta>
    <Description>Immutable Source of Truth for Backend API and Database Schema</Description>
    <Usage>Paste this into the AI Context before generating any API or Data Fetching code.</Usage>
    <Canonical>BearFunds-server · v1.6.1</Canonical>
  </Meta>

  <Protocol>
    <Rule name="Endpoint">Single Entry Point (one POST endpoint). RESTful routes (GET /transactions) DO NOT exist.</Rule>
    <Rule name="Method">POST only.</Rule>
    <Rule name="Auth">Authorization: Bearer &lt;JWT&gt;. Each request carries a Supabase session JWT in the Authorization header. The legacy body "key" field is REMOVED. Unauthenticated/invalid-token requests return { status: 'error' }.</Rule>
    <Rule name="Tenancy">family_id is SERVER-DERIVED from the authenticated session and applied server-side. A client-supplied family_id/user_id in the body is ignored/overwritten. Row-Level Security enforces per-family isolation as the backstop.</Rule>
    <Rule name="Concurrency">Client must use a Request Queue. Network calls are strictly serial.</Rule>
    <Rule name="ErrorHandling">Strict. Unknown keys in payload will trigger a generic API error.</Rule>
  </Protocol>

  <Payloads>
    <Action name="read">
      <Description>Delta Sync. Returns rows modified since timestamp.</Description>
      <Example>
        <![CDATA[
        { "action": "read", "table": "TRANSACTIONS", "since": "2024-01-01T00:00:00Z" }
        ]]>
      </Example>
    </Action>
    <Action name="batchCreate">
      <Description>Bulk Insert. ID is optional (generated by server if missing).</Description>
      <Example>
        <![CDATA[
        {
          "action": "batchCreate",
          "table": "TRANSACTIONS",
          "rows": [ { "date": "2024-01-01", "amount": 20, "category_id": "..." } ]
        }
        ]]>
      </Example>
    </Action>
    <Action name="batchUpdate">
      <Description>Bulk Edit. Updates ONLY the specific keys provided.</Description>
      <Example>
        <![CDATA[
        {
          "action": "batchUpdate",
          "table": "TRANSACTIONS",
          "updates": [ { "id": "uuid-1", "amount": 55.00 } ]
        }
        ]]>
      </Example>
    </Action>
    <Action name="batchUpsert">
      <Description>Idempotent Save. Creates if ID missing, Updates if ID exists. Best for Seeding Test Data and sync creates.</Description>
      <Example>
        <![CDATA[
        {
          "action": "batchUpsert",
          "table": "WALLETS",
          "rows": [ { "id": "w001", "name": "Seed Wallet", "currency": "EUR" } ]
        }
        ]]>
      </Example>
    </Action>
    <Action name="wipe">
      <Description>Destructive (Test Mode Only). Clears all data in the specified table for the caller's family.</Description>
      <Example>
        <![CDATA[
        { "action": "wipe", "table": "TRANSACTIONS" }
        ]]>
      </Example>
    </Action>
  </Payloads>

  <DatabaseSchema>
    <Note>These are LOGICAL KEYS (snake_case). Do not use physical Table Headers.</Note>

    <GlobalColumns>
      <Column key="family_id" type="String (UUID)" sync="server-derived" description="Tenancy key. Derived from the session; NEVER accepted from the client body. Present on all domain tables." />
      <Column key="updated_at" type="ISO String" description="Auto-managed by Server (trigger)." />
      <Column key="deleted" type="Boolean" description="Soft Delete flag." />
      <Column key="is_immutable" type="Boolean" description="System object protection." />
    </GlobalColumns>

    <Table name="FAMILIES" key="FAMILIES">
      <Column key="id" type="String (UUID)" description="Primary Key. Tenancy root." />
      <Column key="name" type="String" description="Family display name." />
      <Column key="created_at" type="ISO String" description="Server-managed creation timestamp." />
    </Table>

    <Table name="TRANSACTIONS" key="TRANSACTIONS">
      <Column key="id" type="String" description="Primary Key as UUID, or special cases for 'immutable / test' logic" />
      <Column key="date" type="String" description="ISO YYYY-MM-DD" />
      <Column key="amount" type="Number" description="Absolute Value" />
      <Column key="currency" type="String" description="ISO (EUR, USD)" />
      <Column key="type" type="String" description="'income', 'expense'" />
      <Column key="category_id" type="String" description="FK -> Categories" />
      <Column key="sub_category" type="String" description="Text value" />
      <Column key="entity_id" type="String" description="FK -> Entities" />
      <Column key="wallet_id" type="String" description="FK -> Wallets" />
      <Column key="member_id" type="String" description="FK -> Members" />
      <Column key="description" type="String" description="Notes/Memo" />
      <Column key="tags" type="String" description="Uppercase only, whitespace permisable, JSON string, e.g. [&quot;TAG 1&quot;, &quot;TAG @2&quot;]" />
      <Column key="status" type="String" description="'cleared', 'pending'" />
    </Table>

    <Table name="CATEGORIES" key="CATEGORIES">
      <Column key="id" type="String" description="Primary Key, formatted as 'c001', or special cases for 'immutable' logic" />
      <Column key="name" type="String" description="Display Name" />
      <Column key="type" type="String" description="'income' or 'expense'" />
      <Column key="sub_categories" type="String" description="JSON Array or Comma-separated" />
      <Column key="icon" type="String" description="Emoji/Icon ID" />
      <Column key="color" type="String" description="Hex Code" />
    </Table>

    <Table name="WALLETS" key="WALLETS">
      <Column key="id" type="String" description="Primary Key, formatted as 'w001', or special cases for 'immutable' logic" />
      <Column key="name" type="String" description="Bank/Account Name" />
      <Column key="currency" type="String" description="ISO Code" />
      <Column key="icon" type="String" />
      <Column key="color" type="String" />
      <Column key="description" type="String" />
      <Column key="is_default" type="Boolean" />
    </Table>

    <Table name="ENTITIES" key="ENTITIES">
      <Column key="id" type="String" description="Primary Key, formatted as 'e001', or special cases for 'immutable' logic" />
      <Column key="name" type="String" description="Store/Payee Name" />
      <Column key="aliases" type="String" description="JSON Array of alternate names" />
      <Column key="match_patterns" type="String" description="Regex strings" />
      <Column key="default_category_id" type="String" />
      <Column key="default_sub_category" type="String" />
      <Column key="icon" type="String" />
      <Column key="color" type="String" />
    </Table>

    <Table name="MEMBERS" key="MEMBERS">
      <Column key="id" type="String" description="Primary Key, formatted as 'm001', or special cases for 'immutable' logic" />
      <Column key="name" type="String" />
      <Column key="role" type="String" description="'admin', 'member'" />
      <Column key="is_me" type="Boolean" description="Flag for current user" />
      <Column key="avatar" type="String" description="URL or Base64" />
      <Column key="color" type="String" />
    </Table>
  </DatabaseSchema>
</SchemaContract>